TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=some-random-secret-string
PUBLIC_URL=https://your-domain.com
ADMIN_IDS=123456789
ADMIN_USERNAMES=your_tg_username
CHANNEL_URL=https://t.me/your_channel
SKIP_INIT_DATA_CHECK=false

# --- Ассистент / LLM ---
# Вариант 1: Google Gemini (БЕСПЛАТНО, рекомендуем)
#   Получи ключ тут: https://aistudio.google.com/app/apikey
#   Поддерживает 60 запросов/мин бесплатно, карта не нужна.
# LLM_PROVIDER=gemini
# LLM_API_KEY=AIzaSy...
# LLM_MODEL=gemini-1.5-flash

# Вариант 2: OpenRouter (платный, но дешёвый)
#   Регистрация: https://openrouter.ai
#   GPT-4o-mini ~$0.15/млн токенов
LLM_PROVIDER=openrouter
LLM_API_KEY=your_openrouter_key_here
LLM_MODEL=minimax/minimax-m2.5
LLM_BASE_URL=https://openrouter.ai/api/v1

# Общие настройки
LLM_MAX_TOKENS=800
LLM_TEMPERATURE=0.7
ASSISTANT_MAX_CHUNKS=5
ASSISTANT_RATE_LIMIT_MINUTES=1
